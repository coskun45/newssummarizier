# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Database
DATABASE_URL=sqlite:///./news_summary.db
CHECKPOINTS_DB=checkpoints.db

# Application Settings
APP_NAME=News Summarizer
APP_VERSION=1.0.0
DEBUG=True

# RSS Feed Configuration
DEFAULT_FEED_URL=https://rss.dw.com/atom/rss-de-all
FEED_REFRESH_INTERVAL=1800  # seconds (30 minutes)

# Scraping Configuration
SCRAPING_ENABLED=True
SCRAPING_DELAY=1.0  # seconds between requests
MAX_RETRIES=3

# OpenAI Configuration
DEFAULT_MODEL=gpt-3.5-turbo
DETAILED_MODEL=gpt-4-turbo-preview
MAX_TOKENS_INPUT=4000
MAX_TOKENS_OUTPUT_BRIEF=150
MAX_TOKENS_OUTPUT_STANDARD=300
MAX_TOKENS_OUTPUT_DETAILED=1000

# Cost Management
DAILY_COST_LIMIT=5.0  # USD
MONTHLY_COST_LIMIT=100.0  # USD

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
